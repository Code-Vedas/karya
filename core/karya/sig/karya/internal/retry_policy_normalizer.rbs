module Karya
  module Internal
    # Shared validation for optional retry policy collaborators.
    class RetryPolicyNormalizer
      @value: RetryPolicy?
      @error_class: Karya::error_class

      def initialize: (RetryPolicy? value, error_class: Karya::error_class) -> void

      def normalize: () -> RetryPolicy?

      private

      attr_reader error_class: Karya::error_class
      attr_reader value: RetryPolicy?
    end
  end
end
