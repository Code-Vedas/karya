module Karya
  class Worker
    # Encapsulates the worker polling loop and associated runtime-state updates.
    class RunSession
      def initialize: (
        worker: Worker,
        iteration_limit: Internal::RuntimeSupport::IterationLimit,
        normalized_poll_interval: Numeric,
        shutdown_controller: Worker::ShutdownController | Worker::InactiveShutdownController,
        stop_when_idle: bool
      ) -> void

      def call: () -> Job?

      private

      def run_iteration: () -> Karya::worker_iteration_result

      def resolve_loop_result: (Karya::worker_iteration_result result) -> Karya::worker_loop_result

      def report_loop_state: (Karya::worker_loop_result loop_result, Karya::worker_iteration_result result) -> nil

      def sleep_if_needed: (Karya::worker_iteration_result result) -> nil

      def stop_loop: () -> nil
    end
  end
end
