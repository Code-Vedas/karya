module Karya
  class Job
    # Normalizes and deeply freezes job arguments so job instances remain immutable.
    class ImmutableArguments
      @arguments: Hash[Karya::state_name, Karya::job_argument]

      IMMUTABLE_SCALAR_CLASSES: Array[singleton(NilClass) | singleton(Numeric) | singleton(Symbol) | singleton(TrueClass) | singleton(FalseClass)]
      DUPLICABLE_SCALAR_CLASSES: Array[singleton(String) | singleton(Time)]
      TraversalTracker: singleton(Internal::ImmutableArgumentGraph::TraversalTracker)
      NormalizedGraph: singleton(Internal::ImmutableArgumentGraph::NormalizedGraph)

      def initialize: (Hash[Karya::state_name, Karya::job_argument] arguments) -> void
      def normalize: () -> Karya::job_arguments

      private

      attr_reader arguments: Hash[Karya::state_name, Karya::job_argument]
    end
  end
end
