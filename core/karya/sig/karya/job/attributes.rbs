module Karya
  class Job
    # Normalizes constructor input without leaking validation helpers onto the public job API.
    class Attributes
      @attributes: Hash[Symbol, Karya::job_attribute_value]

      def initialize: (Hash[Symbol, Karya::job_attribute_value] attributes) -> void

      def to_h: () -> {
        id: String,
        queue: String,
        handler: String,
        arguments: Karya::job_arguments,
        priority: Integer,
        concurrency_key: String?,
        rate_limit_key: String?,
        retry_policy: Karya::retry_policy?,
        execution_timeout: Numeric?,
        expires_at: Time?,
        lifecycle: Karya::lifecycle,
        state: Karya::state_name,
        attempt: Integer,
        created_at: Time,
        updated_at: Time,
        next_retry_at: Time?,
        failure_classification: Karya::failure_classification?
      }

      private

      attr_reader attributes: Hash[Symbol, Karya::job_attribute_value]

      def required: (Symbol name) -> Karya::job_attribute_value

      def optional: (Symbol name, Karya::job_attribute_value? default) -> Karya::job_attribute_value?

      def normalized_attributes: (
        created_at: Time,
        lifecycle: Karya::lifecycle,
        attempt: Integer,
        priority: Integer
      ) -> {
        id: String,
        queue: String,
        handler: String,
        arguments: Karya::job_arguments,
        priority: Integer,
        concurrency_key: String?,
        rate_limit_key: String?,
        retry_policy: Karya::retry_policy?,
        execution_timeout: Numeric?,
        expires_at: Time?,
        lifecycle: Karya::lifecycle,
        state: Karya::state_name,
        attempt: Integer,
        created_at: Time,
        updated_at: Time,
        next_retry_at: Time?,
        failure_classification: Karya::failure_classification?
      }

      def normalize_attempt: () -> Integer

      def normalize_priority: () -> Integer

      def normalize_created_at: () -> Time

      def normalize_updated_at: (Time created_at) -> Time

      def normalize_optional_time: (Symbol name) -> Time?

      def normalize_lifecycle: () -> Karya::lifecycle

      def normalize_optional_positive_finite_number: (Symbol name) -> Numeric?

      def normalize_optional_identifier: (Symbol name) -> String?

      def normalize_retry_policy: () -> Karya::retry_policy?

      def normalize_failure_classification: () -> Karya::failure_classification?

      # Normalizes required identifier-like fields into frozen, non-blank strings.
      class IdentifierNormalizer
        @name: Symbol

        @value: Karya::state_name | Integer

        def initialize: (Symbol name, Karya::state_name | Integer value) -> void

        def normalize: () -> String

        private

        attr_reader name: Symbol

        attr_reader value: Karya::state_name | Integer
      end

      # Normalizes timestamps into frozen copies so jobs cannot mutate caller-owned Time objects.
      class TimestampNormalizer
        @name: Symbol

        @value: Time

        def initialize: (Symbol name, Time value) -> void

        def normalize: () -> Time

        private

        attr_reader name: Symbol

        attr_reader value: Time
      end

      class OptionalIdentifierNormalizer
        @name: Symbol
        @value: Karya::state_name?

        def initialize: (Symbol name, Karya::state_name? value) -> void

        def normalize: () -> String?

        private

        attr_reader name: Symbol

        attr_reader value: Karya::state_name?
      end
    end
  end
end
