module Karya
  module Primitives
    # Validates callable dependencies.
    class Callable
      @name: Symbol

      @value: Karya::callable_value

      @error_class: Karya::error_class

      def initialize: (Symbol name, Karya::callable_value value, error_class: Karya::error_class) -> void

      def normalize: () -> Karya::callable_value

      private

      attr_reader name: Symbol

      attr_reader value: Karya::callable_value

      attr_reader error_class: Karya::error_class
    end
  end
end
