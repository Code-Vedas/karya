module Karya
  module Primitives
    # Validates positive integer values.
    class PositiveInteger
      @name: Symbol

      @value: Integer

      @error_class: Karya::error_class

      def initialize: (Symbol name, Integer value, error_class: Karya::error_class) -> void

      def normalize: () -> Integer

      private

      attr_reader name: Symbol

      attr_reader value: Integer

      attr_reader error_class: Karya::error_class
    end
  end
end
