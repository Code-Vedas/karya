module Karya
  module QueueStore
    # Backend-facing contract for queue persistence and reservation behavior.
    module Base
      def enqueue: (job: Job, now: Time) -> Job

      def reserve: (
        worker_id: String,
        lease_duration: Karya::lease_duration_value,
        now: Time,
        ?queue: String?,
        ?queues: Array[String]?,
        ?handler_names: Array[String]?
      ) -> Reservation?

      def release: (reservation_token: String, now: Time) -> Job

      def start_execution: (reservation_token: String, now: Time) -> Job

      def complete_execution: (reservation_token: String, now: Time) -> Job

      def fail_execution: (
        reservation_token: String,
        now: Time,
        failure_classification: failure_classification_input,
        ?retry_policy: RetryPolicy?
      ) -> Job

      def recover_orphaned_jobs: (worker_id: String, now: Time) -> Array[Job]

      def recover_in_flight: (now: Time) -> RecoveryReport

      def expire_reservations: (now: Time) -> Array[Job]

      def expire_jobs: (now: Time) -> Array[Job]
    end
  end
end
