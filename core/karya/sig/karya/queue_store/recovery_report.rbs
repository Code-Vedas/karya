module Karya
  module QueueStore
    # Immutable result for one in-flight recovery pass.
    class RecoveryReport
      @recovered_at: Time
      @expired_jobs: Array[Job]
      @recovered_reserved_jobs: Array[Job]
      @recovered_running_jobs: Array[Job]

      attr_reader recovered_at: Time
      attr_reader expired_jobs: Array[Job]
      attr_reader recovered_reserved_jobs: Array[Job]
      attr_reader recovered_running_jobs: Array[Job]

      def initialize: (
        recovered_at: Time,
        expired_jobs: Array[Job],
        recovered_reserved_jobs: Array[Job],
        recovered_running_jobs: Array[Job]
      ) -> void

      def jobs: () -> Array[Job]
      def recovered_jobs: () -> Array[Job]

      private

      class JobGroup
        @name: Symbol
        @jobs: Array[Job]

        def initialize: (Symbol name, Array[Job] jobs) -> void

        def to_a: () -> Array[Job]

        private

        attr_reader jobs: Array[Job]
        attr_reader name: Symbol
      end
    end
  end
end
