module Karya
  module QueueStore
    # Single-process reference implementation for queue submission and reservation behavior.
    class InMemory
      @token_generator: Karya::callable_value
      @policy_set: Backpressure::PolicySet
      @circuit_breaker_policy_set: CircuitBreaker::PolicySet
      @fairness_policy: Fairness::Policy
      @completed_batch_retention_limit: Integer
      @max_batch_size: Integer
      @reservation_token_sequence: Integer
      @mutex: Thread::Mutex
      @state: Internal::StoreState

      include Base

      DEFAULT_EXPIRED_TOMBSTONE_LIMIT: 1024
      DEFAULT_COMPLETED_BATCH_RETENTION_LIMIT: 1024
      DEFAULT_MAX_BATCH_SIZE: 1000
      RESERVE_QUEUES_ERROR_MESSAGE: String

      def initialize: (
        ?token_generator: Karya::callable_value,
        ?expired_tombstone_limit: Integer,
        ?completed_batch_retention_limit: Integer,
        ?max_batch_size: Integer,
        ?policy_set: Backpressure::PolicySet,
        ?circuit_breaker_policy_set: CircuitBreaker::PolicySet,
        ?fairness_policy: Fairness::Policy
      ) -> void

      def enqueue: (job: Job, now: Time) -> Job
      def enqueue_many: (jobs: Array[Job], now: Time, ?batch_id: Karya::state_name?) -> BulkMutationReport
      def batch_snapshot: (batch_id: Karya::state_name, now: Time) -> Karya::Workflow::BatchSnapshot
      def enqueue_workflow: (
        definition: Karya::Workflow::Definition,
        jobs_by_step_id: Hash[Karya::state_name, Job],
        batch_id: Karya::state_name,
        now: Time,
        ?compensation_jobs_by_step_id: Hash[Karya::state_name, Job]
      ) -> BulkMutationReport
      def workflow_snapshot: (batch_id: Karya::state_name, now: Time) -> Karya::Workflow::Snapshot
      def enqueue_child_workflow: (
        parent_batch_id: Karya::state_name,
        parent_step_id: Karya::state_name,
        definition: Karya::Workflow::Definition,
        jobs_by_step_id: Hash[Karya::state_name, Job],
        batch_id: Karya::state_name,
        now: Time,
        ?compensation_jobs_by_step_id: Hash[Karya::state_name, Job]
      ) -> BulkMutationReport
      def sync_child_workflows: (parent_batch_id: Karya::state_name, now: Time) -> BulkMutationReport
      def rollback_workflow: (batch_id: Karya::state_name, now: Time, reason: String) -> BulkMutationReport
      def retry_workflow_steps: (batch_id: Karya::state_name, step_ids: Array[Karya::state_name], now: Time) -> BulkMutationReport
      def dead_letter_workflow_steps: (
        batch_id: Karya::state_name,
        step_ids: Array[Karya::state_name],
        now: Time,
        reason: String
      ) -> BulkMutationReport
      def replay_workflow_steps: (batch_id: Karya::state_name, step_ids: Array[Karya::state_name], now: Time) -> BulkMutationReport
      def retry_dead_letter_workflow_steps: (
        batch_id: Karya::state_name,
        step_ids: Array[Karya::state_name],
        now: Time,
        next_retry_at: Time
      ) -> BulkMutationReport
      def discard_workflow_steps: (batch_id: Karya::state_name, step_ids: Array[Karya::state_name], now: Time) -> BulkMutationReport
      def reserve: (
        worker_id: String,
        lease_duration: Karya::lease_duration_value,
        now: Time,
        ?queue: String?,
        ?queues: Array[String]?,
        ?handler_names: Array[String]?
      ) -> Reservation?
      def release: (reservation_token: String, now: Time) -> Job
      def start_execution: (reservation_token: String, now: Time) -> Job
      def complete_execution: (reservation_token: String, now: Time) -> Job
      def fail_execution: (
        reservation_token: String,
        now: Time,
        failure_classification: failure_classification_input,
        ?retry_policy: RetryPolicy?
      ) -> Job
      def retry_jobs: (job_ids: Array[String], now: Time) -> BulkMutationReport
      def cancel_jobs: (job_ids: Array[String], now: Time) -> BulkMutationReport
      def dead_letter_jobs: (job_ids: Array[String], now: Time, reason: String) -> BulkMutationReport
      def replay_dead_letter_jobs: (job_ids: Array[String], now: Time) -> BulkMutationReport
      def retry_dead_letter_jobs: (job_ids: Array[String], now: Time, next_retry_at: Time) -> BulkMutationReport
      def discard_dead_letter_jobs: (job_ids: Array[String], now: Time) -> BulkMutationReport
      def pause_queue: (queue: String, now: Time) -> QueueControlResult
      def resume_queue: (queue: String, now: Time) -> QueueControlResult
      def recover_orphaned_jobs: (worker_id: String, now: Time) -> Array[Job]
      def recover_in_flight: (now: Time) -> RecoveryReport
      def expire_reservations: (now: Time) -> Array[Job]
      def expire_jobs: (now: Time) -> Array[Job]

      # Inspection helper exposed only by QueueStore::InMemory.
      # It is not part of QueueStore::Base, and other queue-store backends are
      # not expected to implement it. Callers that need backend-portable queue
      # store behavior must not rely on this API.
      def backpressure_snapshot: (now: Time) -> Karya::backpressure_snapshot

      # Inspection helper exposed only by QueueStore::InMemory.
      # It is not part of QueueStore::Base, and other queue-store backends are
      # not expected to implement it. Callers that need backend-portable queue
      # store behavior must not rely on this API.
      def reliability_snapshot: (now: Time) -> Karya::reliability_snapshot

      # Inspection helper exposed only by QueueStore::InMemory.
      # It is not part of QueueStore::Base, and other queue-store backends are
      # not expected to implement it. Callers that need backend-portable queue
      # store behavior must not rely on this API.
      def uniqueness_decision: (job: Job, now: Time) -> Karya::uniqueness_decision

      # Inspection helper exposed only by QueueStore::InMemory.
      # It is not part of QueueStore::Base, and other queue-store backends are
      # not expected to implement it. Callers that need backend-portable queue
      # store behavior must not rely on this API.
      def uniqueness_snapshot: (now: Time) -> Karya::uniqueness_snapshot

      # Inspection helper exposed only by QueueStore::InMemory.
      # It is not part of QueueStore::Base, and other queue-store backends are
      # not expected to implement it. Callers that need backend-portable queue
      # store behavior must not rely on this API.
      def dead_letter_snapshot: (now: Time) -> Karya::dead_letter_snapshot

      private

      attr_reader circuit_breaker_policy_set: CircuitBreaker::PolicySet
      attr_reader completed_batch_retention_limit: Integer
      attr_reader fairness_policy: Fairness::Policy
      attr_reader max_batch_size: Integer
      attr_reader policy_set: Backpressure::PolicySet
      attr_reader state: Internal::StoreState
      attr_reader token_generator: Karya::callable_value

      def validate_initializer_limits: (
        expired_tombstone_limit: Integer?,
        completed_batch_retention_limit: Integer?,
        max_batch_size: Integer?
      ) -> nil
      def validate_enqueue: (Job job) -> nil
      def expire_reservations_locked: (Time now) -> Array[Job]
      def prepare_backpressure_snapshot: (Time now) -> void
      def recover_in_flight_locked: (Time now, ?worker_id: String?, ?include_global_maintenance: bool) -> RecoveryReport
      def perform_reserve_maintenance: (Time now) -> Internal::ReserveScanState
      def normalize_identifier: (Symbol name, String value, error_class: Karya::error_class) -> String
      def normalize_time: (Symbol name, Time value, error_class: Karya::error_class) -> Time
      def store_and_requeue_if_needed: (Job job) -> Job
      def reserve_matching_job: (
        handler_matcher: Internal::HandlerMatcher,
        lease_duration: Karya::lease_duration_value,
        now: Time,
        queues: Array[String],
        subscription_key: [Array[String], Array[String]?],
        worker_id: String
      ) -> Reservation?
      def reserve_job: (
        matched_queue: String,
        matched_job_id: String,
        matched_job_index: Integer,
        worker_id: String,
        lease_duration: Karya::lease_duration_value,
        queues: Array[String],
        subscription_key: [Array[String], Array[String]?],
        now: Time
      ) -> Reservation
      def track_fairness_history?: (Array[String] queues) -> bool
      def raise_expired_reservation_error: (String reservation_token, String reservation_label) -> nil
      def fetch_workflow_registration: (String batch_id) -> Internal::StoreState::WorkflowRegistration
      def workflow_control_report: (
        action: Karya::bulk_mutation_action,
        batch_id: Karya::state_name,
        step_ids: Array[Karya::state_name],
        now: Time
      ) { (String, Array[Job], Array[Karya::bulk_skipped_job]) -> void } -> BulkMutationReport
      def workflow_control_job_ids: (Karya::state_name batch_id, Array[Karya::state_name] step_ids) -> Array[String]
      def workflow_dependencies_satisfied?: (Job job, now: Time) -> bool
      def workflow_child_satisfied?: (Job job, now: Time) -> bool
    end
  end
end
