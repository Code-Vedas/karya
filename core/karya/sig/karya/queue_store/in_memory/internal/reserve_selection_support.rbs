module Karya
  module QueueStore
    class InMemory
      module Internal
        module ReserveSelectionSupport
          private

          class FairQueueOrder
            def initialize: (queues: Array[String], strategy: Karya::normalized_fairness_strategy, last_reserved_queue: String?) -> void
            def to_a: () -> Array[String]
          end

          def find_reserved_job: (Array[String] queues, [Array[String], Array[String]?] subscription_key, Internal::HandlerMatcher handler_matcher, Internal::ReserveScanState reserve_scan_state, Time now) -> [String, Integer, String]?
          def fair_queue_order: (Array[String] queues, [Array[String], Array[String]?] subscription_key) -> Array[String]
          def matching_job_for: (String queue, Internal::HandlerMatcher handler_matcher, Internal::ReserveScanState reserve_scan_state, Time now) -> [Integer, String]?
        end
      end
    end
  end
end
