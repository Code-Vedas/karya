module Karya
  # Raised when a canonical job attribute is invalid.
  class InvalidJobAttributeError < Error
  end

  # Immutable value object for the canonical queued job model.
  class Job
    class Identity
      @id: String
      @queue: String
      @handler: String
      @arguments: job_arguments

      attr_reader id: String
      attr_reader queue: String
      attr_reader handler: String
      attr_reader arguments: job_arguments
    end

    class Scheduling
      @priority: Integer
      @concurrency_scope: Backpressure::Scope?
      @rate_limit_scope: Backpressure::Scope?
      @retry_policy: RetryPolicy?
      @execution_timeout: Numeric?
      @expires_at: Time?
      @idempotency_key: String?
      @uniqueness_key: String?
      @uniqueness_scope: uniqueness_scope?

      attr_reader priority: Integer
      attr_reader concurrency_scope: Backpressure::Scope?
      attr_reader rate_limit_scope: Backpressure::Scope?
      attr_reader retry_policy: RetryPolicy?
      attr_reader execution_timeout: Numeric?
      attr_reader expires_at: Time?
      attr_reader idempotency_key: String?
      attr_reader uniqueness_key: String?
      attr_reader uniqueness_scope: uniqueness_scope?
    end

    class LifecycleState
      @state: state_name
      @attempt: Integer
      @created_at: Time
      @updated_at: Time
      @next_retry_at: Time?
      @failure_classification: failure_classification?
      @dead_letter_reason: String?
      @dead_lettered_at: Time?
      @dead_letter_source_state: state_name?
      @lifecycle: JobLifecycle::Registry

      attr_reader state: state_name
      attr_reader attempt: Integer
      attr_reader created_at: Time
      attr_reader updated_at: Time
      attr_reader next_retry_at: Time?
      attr_reader failure_classification: failure_classification?
      attr_reader dead_letter_reason: String?
      attr_reader dead_lettered_at: Time?
      attr_reader dead_letter_source_state: state_name?
      attr_reader lifecycle: JobLifecycle::Registry
    end

    @identity: Identity
    @scheduling: Scheduling
    @lifecycle_state: LifecycleState

    attr_reader arguments: job_arguments

    attr_reader attempt: Integer
    attr_reader concurrency_key: String?
    attr_reader concurrency_scope: Backpressure::Scope?

    attr_reader created_at: Time

    attr_reader handler: String

    attr_reader id: String
    attr_reader priority: Integer

    attr_reader queue: String
    attr_reader rate_limit_key: String?
    attr_reader rate_limit_scope: Backpressure::Scope?
    attr_reader retry_policy: RetryPolicy?
    attr_reader execution_timeout: Numeric?
    attr_reader expires_at: Time?
    attr_reader idempotency_key: String?
    attr_reader uniqueness_key: String?
    attr_reader uniqueness_scope: uniqueness_scope?

    attr_reader state: state_name

    attr_reader updated_at: Time
    attr_reader next_retry_at: Time?
    attr_reader failure_classification: failure_classification?
    attr_reader dead_letter_reason: String?
    attr_reader dead_lettered_at: Time?
    attr_reader dead_letter_source_state: state_name?

    def initialize: (
      id: state_name,
      queue: state_name,
      handler: state_name,
      ?arguments: Hash[state_name, job_argument],
      ?priority: Integer,
      ?concurrency_scope: Karya::backpressure_scope_input?,
      ?rate_limit_scope: Karya::backpressure_scope_input?,
      ?concurrency_key: state_name?,
      ?rate_limit_key: state_name?,
      ?retry_policy: Karya::retry_policy_reference?,
      ?retry_policies: Karya::retry_policy_set_input?,
      ?execution_timeout: Numeric?,
      ?expires_at: Time?,
      ?idempotency_key: job_attribute_value?,
      ?uniqueness_key: job_attribute_value?,
      ?uniqueness_scope: uniqueness_scope_input?,
      state: state_name,
      ?attempt: Integer,
      created_at: Time,
      ?lifecycle: JobLifecycle::Registry,
      ?updated_at: Time,
      ?next_retry_at: Time?,
      ?failure_classification: failure_classification_input?,
      ?dead_letter_reason: String?,
      ?dead_lettered_at: Time?,
      ?dead_letter_source_state: state_name?
    ) -> void

    def can_transition_to?: (state_name next_state) -> bool

    def transition_to: (
      state_name next_state,
      updated_at: Time,
      ?attempt: Integer,
      ?retry_policy: RetryPolicy?,
      ?next_retry_at: Time?,
      ?failure_classification: failure_classification_input?,
      ?dead_letter_reason: String?,
      ?dead_lettered_at: Time?,
      ?dead_letter_source_state: state_name?,
      ?execution_timeout: Numeric?,
      ?expires_at: Time?
    ) -> Job

    def expire: (updated_at: Time) -> Job

    def terminal?: () -> bool

    private

    attr_reader identity: Identity
    attr_reader scheduling: Scheduling
    attr_reader lifecycle_state: LifecycleState

    def lifecycle: () -> JobLifecycle::Registry

    def normalize_transition_overrides: (
      Hash[Symbol, String? | Time? | state_name? | Numeric?] overrides
    ) -> {
      dead_letter_reason: String?,
      dead_lettered_at: Time?,
      dead_letter_source_state: state_name?,
      execution_timeout: Numeric?,
      expires_at: Time?
    }
  end
end
