module Karya
  interface _Lifecycle
    def normalize_state: (state_name state) -> state_name
    def validate_state!: (state_name state) -> state_name
    def valid_transition?: (from: state_name, to: state_name) -> bool
    def validate_transition!: (from: state_name, to: state_name) -> state_name
    def terminal?: (state_name state) -> bool
  end

  interface _CallableValue
    def call: (*callable_argument args) -> callable_result
  end

  type lifecycle = _Lifecycle
  type callable_argument = nil | bool | Numeric | String | Symbol | Time | context_payload | signal_handler | Array[String]
  type callable_result = nil | bool | Numeric | String | Symbol | Time | signal_restorer | context_payload | Array[String]
  type callable_value = Method | Proc | _CallableValue
  type state_name = Symbol | String
  type state_name_array = Array[state_name]
  type normalized_state_name = String
  type normalized_state_name_array = Array[normalized_state_name]
  type normalized_transition_map = Hash[normalized_state_name, normalized_state_name_array]
  type handler_parameter = [Symbol, Symbol?]
  type handler_parameters = Array[handler_parameter]
  type handler_dispatch_mode = :none | :positional_hash | :keywords
  type job_argument = nil | Numeric | String | Symbol | bool | Time | Array[job_argument] | Hash[String, job_argument]
  type job_argument_graph = job_argument | Hash[state_name, job_argument]
  type worker_continue_running = singleton(::Karya::Worker::ContinueRunning)
  type worker_lease_lost = singleton(::Karya::Worker::LeaseLost)
  type worker_no_work_available = singleton(::Karya::Worker::NoWorkAvailable)
  type worker_idle_result = worker_lease_lost | worker_no_work_available
  type worker_iteration_result = Job | worker_idle_result
  type worker_loop_result = Job | worker_continue_running | nil
  type lease_duration_value = Integer | Float | Rational | BigDecimal
  type retry_policy = RetryPolicy
  type retry_policy_reference = RetryPolicy | state_name
  type retry_policy_symbol_required_attributes = {
    max_attempts: Numeric,
    base_delay: Numeric,
    multiplier: Numeric
  }
  type retry_policy_string_required_attributes = {
    "max_attempts" => Numeric,
    "base_delay" => Numeric,
    "multiplier" => Numeric
  }
  type retry_policy_required_attributes =
    retry_policy_symbol_required_attributes |
    retry_policy_string_required_attributes |
    { max_attempts: Numeric, base_delay: Numeric, "multiplier" => Numeric } |
    { max_attempts: Numeric, "base_delay" => Numeric, multiplier: Numeric } |
    { max_attempts: Numeric, "base_delay" => Numeric, "multiplier" => Numeric } |
    { "max_attempts" => Numeric, base_delay: Numeric, multiplier: Numeric } |
    { "max_attempts" => Numeric, base_delay: Numeric, "multiplier" => Numeric } |
    { "max_attempts" => Numeric, "base_delay" => Numeric, multiplier: Numeric }
  type retry_policy_optional_attributes =
    {} |
    { max_delay: Numeric? } |
    { "max_delay" => Numeric? } |
    { jitter_strategy: retry_jitter_strategy } |
    { "jitter_strategy" => retry_jitter_strategy } |
    { escalate_on: Array[failure_classification_input] } |
    { "escalate_on" => Array[failure_classification_input] } |
    { max_delay: Numeric?, jitter_strategy: retry_jitter_strategy } |
    { max_delay: Numeric?, "jitter_strategy" => retry_jitter_strategy } |
    { "max_delay" => Numeric?, jitter_strategy: retry_jitter_strategy } |
    { "max_delay" => Numeric?, "jitter_strategy" => retry_jitter_strategy } |
    { max_delay: Numeric?, escalate_on: Array[failure_classification_input] } |
    { max_delay: Numeric?, "escalate_on" => Array[failure_classification_input] } |
    { "max_delay" => Numeric?, escalate_on: Array[failure_classification_input] } |
    { "max_delay" => Numeric?, "escalate_on" => Array[failure_classification_input] } |
    { jitter_strategy: retry_jitter_strategy, escalate_on: Array[failure_classification_input] } |
    { jitter_strategy: retry_jitter_strategy, "escalate_on" => Array[failure_classification_input] } |
    { "jitter_strategy" => retry_jitter_strategy, escalate_on: Array[failure_classification_input] } |
    { "jitter_strategy" => retry_jitter_strategy, "escalate_on" => Array[failure_classification_input] } |
    { max_delay: Numeric?, jitter_strategy: retry_jitter_strategy, escalate_on: Array[failure_classification_input] } |
    { max_delay: Numeric?, jitter_strategy: retry_jitter_strategy, "escalate_on" => Array[failure_classification_input] } |
    { max_delay: Numeric?, "jitter_strategy" => retry_jitter_strategy, escalate_on: Array[failure_classification_input] } |
    { max_delay: Numeric?, "jitter_strategy" => retry_jitter_strategy, "escalate_on" => Array[failure_classification_input] } |
    { "max_delay" => Numeric?, jitter_strategy: retry_jitter_strategy, escalate_on: Array[failure_classification_input] } |
    { "max_delay" => Numeric?, jitter_strategy: retry_jitter_strategy, "escalate_on" => Array[failure_classification_input] } |
    { "max_delay" => Numeric?, "jitter_strategy" => retry_jitter_strategy, escalate_on: Array[failure_classification_input] } |
    { "max_delay" => Numeric?, "jitter_strategy" => retry_jitter_strategy, "escalate_on" => Array[failure_classification_input] }
  type retry_policy_attributes = retry_policy_required_attributes & retry_policy_optional_attributes
  type retry_policy_set_input = RetryPolicySet | Hash[state_name, RetryPolicy | retry_policy_attributes]
  type backpressure_scope_kind = :queue | :handler | :tenant | :workflow | :custom | "queue" | "handler" | "tenant" | "workflow" | "custom"
  type normalized_backpressure_scope_kind = :queue | :handler | :tenant | :workflow | :custom
  type backpressure_scope_symbol_input = { kind: backpressure_scope_kind, value: state_name }
  type backpressure_scope_string_input = { "kind" => backpressure_scope_kind, "value" => state_name }
  type backpressure_scope_mixed_input =
    { kind: backpressure_scope_kind, "value" => state_name } |
    { "kind" => backpressure_scope_kind, value: state_name }
  type backpressure_scope_hash_input =
    backpressure_scope_symbol_input |
    backpressure_scope_string_input |
    backpressure_scope_mixed_input
  type backpressure_scope_input = Backpressure::Scope | backpressure_scope_hash_input | state_name
  type circuit_breaker_scope_kind = :queue | :handler | "queue" | "handler"
  type circuit_breaker_scope_symbol_input = { kind: circuit_breaker_scope_kind, value: state_name }
  type circuit_breaker_scope_string_input = { "kind" => circuit_breaker_scope_kind, "value" => state_name }
  type circuit_breaker_scope_mixed_input =
    { kind: circuit_breaker_scope_kind, "value" => state_name } |
    { "kind" => circuit_breaker_scope_kind, value: state_name }
  type circuit_breaker_scope_hash_input =
    circuit_breaker_scope_symbol_input |
    circuit_breaker_scope_string_input |
    circuit_breaker_scope_mixed_input
  type circuit_breaker_scope_input = Backpressure::Scope | circuit_breaker_scope_hash_input | state_name
  type concurrency_policy_symbol_attributes = { limit: Integer }
  type concurrency_policy_string_attributes = { "limit" => Integer }
  type concurrency_policy_attributes =
    concurrency_policy_symbol_attributes |
    concurrency_policy_string_attributes |
    { limit: Integer, "limit" => Integer }
  type rate_limit_policy_symbol_attributes = { limit: Integer, period: lease_duration_value }
  type rate_limit_policy_string_attributes = { "limit" => Integer, "period" => lease_duration_value }
  type rate_limit_policy_mixed_attributes =
    { limit: Integer, "period" => lease_duration_value } |
    { "limit" => Integer, period: lease_duration_value }
  type rate_limit_policy_attributes =
    rate_limit_policy_symbol_attributes |
    rate_limit_policy_string_attributes |
    rate_limit_policy_mixed_attributes
  type circuit_breaker_policy_symbol_required_attributes = {
    failure_threshold: Integer,
    window: lease_duration_value,
    cooldown: lease_duration_value
  }
  type circuit_breaker_policy_symbol_optional_attributes =
    {} |
    { half_open_limit: Integer }
  type circuit_breaker_policy_symbol_attributes =
    circuit_breaker_policy_symbol_required_attributes &
    circuit_breaker_policy_symbol_optional_attributes
  type circuit_breaker_policy_string_required_attributes = {
    "failure_threshold" => Integer,
    "window" => lease_duration_value,
    "cooldown" => lease_duration_value
  }
  type circuit_breaker_policy_string_optional_attributes =
    {} |
    { "half_open_limit" => Integer }
  type circuit_breaker_policy_string_attributes =
    circuit_breaker_policy_string_required_attributes &
    circuit_breaker_policy_string_optional_attributes
  type circuit_breaker_policy_mixed_required_attributes =
    { failure_threshold: Integer, window: lease_duration_value, "cooldown" => lease_duration_value } |
    { failure_threshold: Integer, "window" => lease_duration_value, cooldown: lease_duration_value } |
    { failure_threshold: Integer, "window" => lease_duration_value, "cooldown" => lease_duration_value } |
    { "failure_threshold" => Integer, window: lease_duration_value, cooldown: lease_duration_value } |
    { "failure_threshold" => Integer, window: lease_duration_value, "cooldown" => lease_duration_value } |
    { "failure_threshold" => Integer, "window" => lease_duration_value, cooldown: lease_duration_value }
  type circuit_breaker_policy_mixed_optional_attributes =
    {} |
    { half_open_limit: Integer } |
    { "half_open_limit" => Integer }
  type circuit_breaker_policy_mixed_attributes =
    circuit_breaker_policy_mixed_required_attributes &
    circuit_breaker_policy_mixed_optional_attributes
  type circuit_breaker_policy_attributes =
    circuit_breaker_policy_symbol_attributes |
    circuit_breaker_policy_string_attributes |
    circuit_breaker_policy_mixed_attributes
  type retry_decision_action = :retry | :stop | :escalate
  type retry_decision_reason = :classification_escalated | :retry_exhausted
  type retry_jitter_strategy = :none | :full | :equal | "none" | "full" | "equal"
  type uniqueness_scope = :queued | :active | :until_terminal
  type uniqueness_scope_input = uniqueness_scope | "queued" | "active" | "until_terminal"
  type uniqueness_decision_action = :accept | :reject
  type uniqueness_decision_result = :accepted | :duplicate_job_id | :duplicate_idempotency_key | :duplicate_uniqueness_key
  type uniqueness_decision_key_type = :job_id | :idempotency_key | :uniqueness_key
  type bulk_mutation_action = :enqueue_many | :retry_jobs | :cancel_jobs
  type queue_control_action = :pause_queue | :resume_queue
  type bulk_skip_reason = :not_found | :ineligible_state | :duplicate_request | :uniqueness_conflict
  type bulk_skipped_job = {
    job_id: String,
    reason: bulk_skip_reason,
    state: state_name?
  }
  type uniqueness_decision = {
    captured_at: Time,
    job_id: String,
    action: uniqueness_decision_action,
    result: uniqueness_decision_result,
    key_type: uniqueness_decision_key_type?,
    key: String?,
    conflicting_job_id: String?,
    uniqueness_scope: uniqueness_scope?
  }
  type failure_classification = :error | :timeout | :expired
  type failure_classification_input = failure_classification | "error" | "timeout" | "expired"
  type circuit_breaker_state = :closed | :open | :half_open
  type circuit_breaker_runtime_state = { state: circuit_breaker_state, cooldown_until: Time? }
  type stuck_job_recovery = { recovery_count: Integer, last_recovered_at: Time, last_recovery_reason: String }
  type circuit_breaker_snapshot = {
    scope: Backpressure::Scope,
    state: circuit_breaker_state,
    failure_count: Integer,
    failure_threshold: Integer,
    window: lease_duration_value,
    cooldown: lease_duration_value,
    blocked_count: Integer,
    cooldown_until: Time?,
    probe_slots_remaining: Integer?
  }
  type stuck_job_snapshot = {
    job_id: String,
    queue: String,
    handler: String,
    state: state_name,
    attempt: Integer,
    recovery_count: Integer,
    last_recovered_at: Time,
    last_recovery_reason: String
  }
  type reliability_snapshot = {
    captured_at: Time,
    circuit_breakers: Hash[String, circuit_breaker_snapshot],
    stuck_jobs: Hash[String, stuck_job_snapshot]
  }
  type idempotency_key_snapshot = {
    key: String,
    job_id: String,
    queue: String,
    handler: String,
    state: state_name,
    created_at: Time,
    updated_at: Time?
  }
  type uniqueness_key_snapshot = {
    key: String,
    job_id: String,
    queue: String,
    handler: String,
    state: state_name,
    effective_state: state_name,
    uniqueness_scope: uniqueness_scope,
    blocked_incoming_scopes: Array[uniqueness_scope]
  }
  type uniqueness_snapshot = {
    captured_at: Time,
    idempotency_keys: Hash[String, idempotency_key_snapshot],
    uniqueness_keys: Hash[String, Array[uniqueness_key_snapshot]]
  }
  type backpressure_concurrency_snapshot = { scope: Backpressure::Scope, limit: Integer, active_count: Integer, blocked_count: Integer }
  type backpressure_rate_limit_snapshot = {
    scope: Backpressure::Scope,
    limit: Integer,
    period: lease_duration_value,
    window_count: Integer,
    blocked_count: Integer
  }
  type backpressure_snapshot = {
    captured_at: Time,
    concurrency: Hash[String, backpressure_concurrency_snapshot],
    rate_limits: Hash[String, backpressure_rate_limit_snapshot]
  }
  type context_payload = ::Hash[Symbol, job_argument | Integer | Array[Integer] | String]
  type handler_mapping = ::Hash[String, Worker::_Handler]
  type option_value = nil | bool | Numeric | String | Symbol | logger | instrumenter | QueueStore::Base | lifecycle | retry_policy | retry_policy_set_input | Worker::Configuration | Worker::Runtime | WorkerSupervisor::Configuration | WorkerSupervisor::Runtime | Worker::HandlerRegistry | handler_mapping | Array[String] | callable_value | singleton(Worker)
  type symbol_options = ::Hash[Symbol, option_value]
  type mixed_options = ::Hash[Symbol | String, option_value]
  type job_arguments = ::Hash[String, job_argument]
  type error_class = singleton(StandardError)
  type logger = Internal::_Logger
  type instrumenter = ^(String, context_payload) -> nil
  type signal_handler = ^() -> nil
  type signal_restorer = ^() -> nil
  type cli_defaults = Hash[Symbol, Integer]
  type cli_option_scalar = nil | bool | Numeric | String | Symbol
  type cli_option_value = cli_option_scalar | Array[String]
  type cli_options = Hash[Symbol | String, cli_option_value]
  type cli_env_prefix_normalizer = ^(Symbol) -> String?
  type cli_optional_integer_coercer = ^(Symbol) -> Integer?
  type cli_positive_integer_resolver = ^(Symbol, env_prefix: String?, defaults: cli_defaults) -> Integer
  type job_attribute_value =
    job_argument |
    Integer |
    Time |
    retry_policy |
    retry_policy_set_input |
    lifecycle |
    state_name |
    uniqueness_scope_input |
    failure_classification_input |
    backpressure_scope_input
  type reservation_attribute_value = state_name | Integer | Time
end
