#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)
TMP_DIR="${REPO_ROOT}/tmp/bundle-update-all"

mkdir -p "${TMP_DIR}"

run_cmd() {
  name="$1"
  shift
  log_file="${TMP_DIR}/${name}.log"

  echo "==> ${name}"

  if "$@" >"${log_file}" 2>&1; then
    rm -f "${log_file}"
    return 0
  fi

  echo "-- ${name} failed --"
  cat "${log_file}"
  return 1
}

update_bundle_dir() {
  suite_dir="$1"

  [ -f "${REPO_ROOT}/${suite_dir}/Gemfile" ] || return 0

  cd "${REPO_ROOT}/${suite_dir}"
  run_cmd "$(basename "${suite_dir}")-bundle-update" ruby -S bundle update
}

update_yarn_dir() {
  suite_dir="$1"

  [ -f "${REPO_ROOT}/${suite_dir}/package.json" ] || return 0

  cd "${REPO_ROOT}/${suite_dir}"
  run_cmd "$(basename "${suite_dir}")-yarn-upgrade" corepack yarn up --recursive
}

update_bundle_dir "core/karya"
update_bundle_dir "core/karya-activerecord"
update_bundle_dir "core/karya-sequel"
update_bundle_dir "gems/karya-dashboard"
update_bundle_dir "gems/karya-hanami"
update_bundle_dir "gems/karya-rails"
update_bundle_dir "gems/karya-roda"
update_bundle_dir "gems/karya-sinatra"
update_yarn_dir "gems/karya-dashboard"
