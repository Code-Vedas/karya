#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/run-common"
TMP_DIR="${REPO_ROOT}/tmp/bundle-update-all"

mkdir -p "${TMP_DIR}"

update_bundle_dir() {
  suite_dir="$1"
  gemfile_path="${2:-}"

  [ -f "${REPO_ROOT}/${suite_dir}/Gemfile" ] || return 0

  cd "${REPO_ROOT}/${suite_dir}"

  if [ -z "${gemfile_path}" ]; then
    if suite_uses_rails "${suite_dir}"; then
      RUN_ALL_EXPECT_RAILS=1 run_cmd "$(basename "${suite_dir}")-bundle-update" ruby -S bundle update
      return 0
    fi

    run_cmd "$(basename "${suite_dir}")-bundle-update" ruby -S bundle update
    return 0
  fi

  label="$(basename "${suite_dir}")-$(gemfile_label "${gemfile_path}")-bundle-update"
  bundle_gemfile="${REPO_ROOT}/${suite_dir}/${gemfile_path}"
  RUN_ALL_EXPECT_RAILS=1 RUN_ALL_BUNDLE_GEMFILE="${bundle_gemfile}" \
    run_cmd_env "${label}" BUNDLE_GEMFILE="${bundle_gemfile}" ruby -S bundle update
}

update_yarn_dir() {
  suite_dir="$1"

  [ -f "${REPO_ROOT}/${suite_dir}/package.json" ] || return 0

  cd "${REPO_ROOT}/${suite_dir}"
  run_cmd "$(basename "${suite_dir}")-yarn-upgrade" corepack yarn up --recursive
}

ruby_suites > "${TMP_DIR}/ruby-suites.txt"

while IFS= read -r suite_dir; do
  update_bundle_dir "${suite_dir}"
  gemfiles=$(suite_gemfiles "${suite_dir}" || true)
  if [ "${gemfiles}" != "" ]; then
    for gemfile in ${gemfiles}; do
      update_bundle_dir "${suite_dir}" "${gemfile}"
    done
  fi
done < "${TMP_DIR}/ruby-suites.txt"

update_bundle_dir "docs" "Gemfile"

js_suites > "${TMP_DIR}/js-suites.txt"

while IFS= read -r suite_dir; do
  update_yarn_dir "${suite_dir}"
done < "${TMP_DIR}/js-suites.txt"
