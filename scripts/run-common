#!/bin/sh

set -eu

if [ "${SCRIPT_DIR:-}" = "" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fi

if [ "${REPO_ROOT:-}" = "" ]; then
  REPO_ROOT=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)
fi

TMP_DIR="${REPO_ROOT}/tmp/run-all"

mkdir -p "${TMP_DIR}"

reset_terminal_color() {
  printf '\033[0m'
}

runtime_ruby_version() {
  ruby -v 2>/dev/null || true
}

runtime_node_version() {
  node -v 2>/dev/null || true
}

runtime_yarn_version() {
  corepack yarn --version 2>/dev/null || true
}

print_runtime_context() {
  ruby_version=$(runtime_ruby_version)
  node_version=$(runtime_node_version)
  yarn_version=$(runtime_yarn_version)

  [ "${ruby_version}" != "" ] && echo "ruby: ${ruby_version}"
  [ "${node_version}" != "" ] && echo "node: ${node_version}"
  [ "${yarn_version}" != "" ] && echo "yarn: ${yarn_version}"
  echo "pwd: $(pwd)"
}

print_run_summary() {
  log_file="$1"
  summary_lines=$(
    grep -E 'Finished in|examples?, [0-9]+ failures|files? inspected|offenses? detected|total warnings?|Line Coverage:|Branch Coverage:|built in|tests? passed|failed|passed ' "${log_file}" \
      | tail -n 5 || true
  )

  if [ "${summary_lines}" = "" ]; then
    summary_lines=$(
      tail -n 8 "${log_file}" \
        | sed '/^[[:space:]]*$/d' \
        | tail -n 5
    )
  fi

  [ "${summary_lines}" = "" ] && return 0

  echo "run summary:"
  printf '%s\n' "${summary_lines}"
}

run_cmd() {
  name="$1"
  shift
  log_file="${TMP_DIR}/${name}.log"

  reset_terminal_color
  echo "==> ${name}"
  print_runtime_context

  if "$@" >"${log_file}" 2>&1; then
    reset_terminal_color
    print_run_summary "${log_file}"
    reset_terminal_color
    echo
    rm -f "${log_file}"
    return 0
  fi

  reset_terminal_color
  echo "-- ${name} failed --"
  cat "${log_file}"
  reset_terminal_color
  return 1
}

run_cmd_env() {
  name="$1"
  shift
  log_file="${TMP_DIR}/${name}.log"

  reset_terminal_color
  echo "==> ${name}"
  print_runtime_context

  if env "$@" >"${log_file}" 2>&1; then
    reset_terminal_color
    print_run_summary "${log_file}"
    reset_terminal_color
    echo
    rm -f "${log_file}"
    return 0
  fi

  reset_terminal_color
  echo "-- ${name} failed --"
  cat "${log_file}"
  reset_terminal_color
  return 1
}

ruby_suites() {
  cat <<'EOF'
core/karya
core/karya-activerecord
core/karya-sequel
gems/karya-dashboard
gems/karya-hanami
gems/karya-rails
gems/karya-roda
gems/karya-sinatra
EOF
}

js_suites() {
  cat <<'EOF'
gems/karya-dashboard
EOF
}

suite_name() {
  basename "$1"
}

with_repo_dir() {
  suite_dir="$1"
  shift
  cd "${REPO_ROOT}/${suite_dir}"
  "$@"
}

has_executable() {
  suite_dir="$1"
  file_name="$2"
  [ -x "${REPO_ROOT}/${suite_dir}/${file_name}" ]
}

has_package_script() {
  suite_dir="$1"
  script_name="$2"

  [ -f "${REPO_ROOT}/${suite_dir}/package.json" ] || return 1
  grep -q "\"${script_name}\"[[:space:]]*:" "${REPO_ROOT}/${suite_dir}/package.json"
}

yarn_exec() {
  corepack yarn "$@"
}

run_yarn_script() {
  suite_dir="$1"
  script_name="$2"
  label="${3:-$(suite_name "${suite_dir}")-${script_name}}"

  cd "${REPO_ROOT}/${suite_dir}"
  run_cmd "${label}" yarn_exec "${script_name}"
}

run_optional_ruby_bin() {
  suite_dir="$1"
  bin_name="$2"

  if has_executable "${suite_dir}" "bin/${bin_name}"; then
    with_repo_dir "${suite_dir}" run_cmd "$(suite_name "${suite_dir}")-${bin_name}" "bin/${bin_name}"
    return 0
  fi

  echo "Skipping $(suite_name "${suite_dir}") ${bin_name}: missing bin/${bin_name}"
}

run_optional_yarn_script() {
  suite_dir="$1"
  script_name="$2"

  if has_package_script "${suite_dir}" "${script_name}"; then
    run_yarn_script "${suite_dir}" "${script_name}" "$(suite_name "${suite_dir}")-${script_name}"
    return 0
  fi

  echo "Skipping $(suite_name "${suite_dir}") ${script_name}: missing package.json script"
}
