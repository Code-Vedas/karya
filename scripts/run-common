#!/bin/sh

set -eu

if [ "${SCRIPT_DIR:-}" = "" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fi

if [ "${REPO_ROOT:-}" = "" ]; then
  REPO_ROOT=$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)
fi

TMP_DIR="${REPO_ROOT}/tmp/run-all"

mkdir -p "${TMP_DIR}"

reset_terminal_color() {
  printf '\033[0m'
}

runtime_ruby_version() {
  ruby -v 2>/dev/null || true
}

runtime_node_version() {
  node -v 2>/dev/null || true
}

runtime_yarn_version() {
  corepack yarn --version 2>/dev/null || true
}

runtime_rails_version() {
  bundle_gemfile="${RUN_ALL_BUNDLE_GEMFILE:-${BUNDLE_GEMFILE:-}}"

  if [ "${bundle_gemfile}" != "" ]; then
    BUNDLE_GEMFILE="${bundle_gemfile}" bundle exec ruby -e 'require "rails"; puts "rails: #{Rails.version}"' 2>/dev/null || true
    return 0
  fi

  bundle exec ruby -e 'require "rails"; puts "rails: #{Rails.version}"' 2>/dev/null || true
}

print_runtime_context() {
  ruby_version=$(runtime_ruby_version)

  if [ "${ruby_version}" != "" ]; then
    echo "ruby: ${ruby_version}"
  fi

  if [ "${RUN_ALL_EXPECT_NODE:-0}" = "1" ]; then
    node_version=$(runtime_node_version)
    yarn_version=$(runtime_yarn_version)

    if [ "${node_version}" != "" ]; then
      echo "node: ${node_version}"
    fi

    if [ "${yarn_version}" != "" ]; then
      echo "yarn: ${yarn_version}"
    fi
  fi

  if [ "${RUN_ALL_EXPECT_RAILS:-0}" = "1" ]; then
    rails_version=$(runtime_rails_version)

    if [ "${rails_version}" != "" ]; then
      echo "${rails_version}"
    fi
  fi

  echo "pwd: $(pwd)"

  if [ "${RUN_ALL_BUNDLE_GEMFILE:-}" != "" ]; then
    echo "gemfile: $(basename "${RUN_ALL_BUNDLE_GEMFILE}")"
  fi
}

print_run_summary() {
  log_file="$1"
  summary_lines=$(
    grep -E 'Finished in|examples?, [0-9]+ failures|files? inspected|offenses? detected|total warnings?|Line Coverage:|Branch Coverage:|built in|tests? passed|failed|passed ' "${log_file}" \
      | tail -n 5 || true
  )

  if [ "${summary_lines}" = "" ]; then
    summary_lines=$(
      tail -n 8 "${log_file}" \
        | sed '/^[[:space:]]*$/d' \
        | tail -n 5
    )
  fi

  [ "${summary_lines}" = "" ] && return 0

  echo "run summary:"
  printf '%s\n' "${summary_lines}"
}

run_cmd() {
  name="$1"
  shift
  log_file="${TMP_DIR}/${name}.log"

  reset_terminal_color
  echo "==> ${name}"
  print_runtime_context

  if "$@" >"${log_file}" 2>&1; then
    reset_terminal_color
    print_run_summary "${log_file}"
    reset_terminal_color
    echo
    rm -f "${log_file}"
    return 0
  fi

  reset_terminal_color
  echo "-- ${name} failed --"
  cat "${log_file}"
  reset_terminal_color
  return 1
}

run_cmd_env() {
  name="$1"
  shift
  log_file="${TMP_DIR}/${name}.log"

  reset_terminal_color
  echo "==> ${name}"
  print_runtime_context

  if env "$@" >"${log_file}" 2>&1; then
    reset_terminal_color
    print_run_summary "${log_file}"
    reset_terminal_color
    echo
    rm -f "${log_file}"
    return 0
  fi

  reset_terminal_color
  echo "-- ${name} failed --"
  cat "${log_file}"
  reset_terminal_color
  return 1
}

ruby_suites() {
  cat <<'EOF'
core/karya
core/karya-activerecord
core/karya-sequel
gems/karya-dashboard
gems/karya-hanami
gems/karya-rails
gems/karya-roda
gems/karya-sinatra
EOF
}

js_suites() {
  cat <<'EOF'
gems/karya-dashboard
EOF
}

suite_name() {
  basename "$1"
}

suite_uses_rails() {
  case "$1" in
    core/karya-activerecord|gems/karya-rails)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

current_ruby_series() {
  ruby -e 'print RUBY_VERSION.split(".").first(2).join(".")'
}

gemfile_label() {
  basename "$1" .gemfile | tr '_' '-'
}

suite_gemfiles() {
  suite_dir="$1"

  case "${suite_dir}" in
    core/karya-activerecord|gems/karya-rails)
      printf '%s\n' "gemfiles/rails_7_2.gemfile"
      printf '%s\n' "gemfiles/rails_8_0.gemfile"
      printf '%s\n' "gemfiles/rails_8_1.gemfile"
      if [ "$(current_ruby_series)" != "3.2" ]; then
        printf '%s\n' "gemfiles/rails_edge.gemfile"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

with_repo_dir() {
  suite_dir="$1"
  shift
  cd "${REPO_ROOT}/${suite_dir}"
  "$@"
}

has_executable() {
  suite_dir="$1"
  file_name="$2"
  [ -x "${REPO_ROOT}/${suite_dir}/${file_name}" ]
}

has_package_script() {
  suite_dir="$1"
  script_name="$2"

  [ -f "${REPO_ROOT}/${suite_dir}/package.json" ] || return 1
  grep -q "\"${script_name}\"[[:space:]]*:" "${REPO_ROOT}/${suite_dir}/package.json"
}

run_yarn_script() {
  suite_dir="$1"
  script_name="$2"
  label="${3:-$(suite_name "${suite_dir}")-${script_name}}"

  cd "${REPO_ROOT}/${suite_dir}"
  RUN_ALL_EXPECT_NODE=1 run_cmd "${label}" corepack yarn "${script_name}"
}

run_optional_ruby_bin() {
  suite_dir="$1"
  bin_name="$2"
  label="$(suite_name "${suite_dir}")-${bin_name}"

  if has_executable "${suite_dir}" "bin/${bin_name}"; then
    if suite_uses_rails "${suite_dir}"; then
      cd "${REPO_ROOT}/${suite_dir}"
      RUN_ALL_EXPECT_RAILS=1 run_cmd "${label}" "bin/${bin_name}"
      return 0
    fi

    with_repo_dir "${suite_dir}" run_cmd "${label}" "bin/${bin_name}"
    return 0
  fi

  echo "Skipping $(suite_name "${suite_dir}") ${bin_name}: missing bin/${bin_name}"
}

run_optional_yarn_script() {
  suite_dir="$1"
  script_name="$2"

  if has_package_script "${suite_dir}" "${script_name}"; then
    run_yarn_script "${suite_dir}" "${script_name}" "$(suite_name "${suite_dir}")-${script_name}"
    return 0
  fi

  echo "Skipping $(suite_name "${suite_dir}") ${script_name}: missing package.json script"
}
