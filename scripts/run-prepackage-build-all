#!/bin/sh
set -eu

if [ "${SCRIPT_DIR:-}" = "" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fi
. "${SCRIPT_DIR}/run-common"

js_suites > "${TMP_DIR}/js-suites.txt"

while IFS= read -r suite_dir; do
  run_optional_yarn_script "${suite_dir}" "prepackage-build"
done < "${TMP_DIR}/js-suites.txt"
