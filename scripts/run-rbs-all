#!/bin/sh
set -eu

if [ "${SCRIPT_DIR:-}" = "" ]; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
fi
. "${SCRIPT_DIR}/run-common"

run_suite() {
  suite_dir="$1"
  suite_label="$(suite_name "${suite_dir}")"

  if [ ! -d "${REPO_ROOT}/${suite_dir}/sig" ]; then
    echo "Skipping ${suite_label} rbs: missing sig/"
    return 0
  fi

  if rg -n '\b(untyped|top|Object|BasicObject)\b' "${REPO_ROOT}/${suite_dir}/sig" >/dev/null 2>&1; then
    echo "Strict RBS check failed for ${suite_label}: found forbidden generic types in sig/"
    rg -n '\b(untyped|top|Object|BasicObject)\b' "${REPO_ROOT}/${suite_dir}/sig"
    return 1
  fi

  gemfiles=$(suite_gemfiles "${suite_dir}" || true)
  if [ "${gemfiles}" != "" ]; then
    for gemfile in ${gemfiles}; do
      RUN_ALL_EXPECT_RAILS=1 \
      RUN_ALL_BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
      run_cmd_env \
        "${suite_label}-$(gemfile_label "${gemfile}")-rbs" \
        BUNDLE_GEMFILE="${REPO_ROOT}/${suite_dir}/${gemfile}" \
        sh -c "cd \"${REPO_ROOT}/${suite_dir}\" && rbs -I sig validate"
    done
    return 0
  fi

  run_cmd "${suite_label}-rbs" sh -c "cd \"${REPO_ROOT}/${suite_dir}\" && rbs -I sig validate"
}

ruby_suites | while IFS= read -r suite_dir; do
  run_suite "${suite_dir}"
done
