{
  "name": "karya-dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" && stylelint \"src/**/*.scss\"",
    "build": "tsc -b && vite build",
    "prepackage-build": "yarn build && node scripts/verify-dist.mjs",
    "dev": "vite dev --host 0.0.0.0 --port 4173",
    "preview": "vite preview --host 127.0.0.1 --port 4273",
    "firefox:e2e": "yarn prepackage-build && playwright test --project=firefox"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.53.0",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "postcss": "^8.5.3",
    "sass": "^1.89.2",
    "semver": "^7.7.2",
    "stylelint": "^16.23.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  }
}
