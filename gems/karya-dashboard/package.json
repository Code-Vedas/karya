{
  "name": "karya-dashboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "type": "module",
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" && stylelint \"src/**/*.scss\"",
    "build": "tsc -b && vite build",
    "prepackage-build": "yarn build && node scripts/verify-dist.mjs",
    "dev": "vite dev --host 0.0.0.0 --port 4173",
    "preview": "vite preview --host 127.0.0.1 --port 4273",
    "firefox:e2e": "yarn prepackage-build && yarn exec -- playwright test --project=firefox"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "sass": "^1.99.0",
    "semver": "^7.7.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.6"
  }
}
