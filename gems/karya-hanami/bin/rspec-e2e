ADAPTER="${1:-nshift}"  # default adapter
shift || true            # remove first arg, leave the rest in "$@"
set -euo pipefail
# Run RSpec with environment variables and proper tags
E2E="1" NO_COVERAGE=1 bin/rspec spec/e2e --tag "integration:${ADAPTER}" "$@"
